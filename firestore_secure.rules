rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Bookings collection - users can read/write their own bookings
    match /bookings/{documentId} {
      allow read, write: if isOwner(resource.data.userId) || 
                        isOwner(request.resource.data.userId);
    }
    
    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Notifications collection - users can read/write their own notifications
    match /notifications/{notificationId} {
      allow read, write: if isOwner(resource.data.userId) || 
                        isOwner(request.resource.data.userId);
    }
    
    // Live tracking collection - allow read/write for tracking purposes
    match /live_tracking/{trackingId} {
      allow read, write: if isAuthenticated();
    }
    
    // Tracking events collection - allow read/write for tracking purposes
    match /tracking_events/{eventId} {
      allow read, write: if isAuthenticated();
    }
  }
}
